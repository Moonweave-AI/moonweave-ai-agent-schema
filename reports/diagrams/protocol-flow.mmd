flowchart TB
  User["User request"] --> Agent["Agent runtime"]
  Agent --> ToolChoice["Tool selection"]
  ToolChoice --> MCP["MCP tool/resource/prompt server"]
  Agent --> Delegate["Delegation decision"]
  Delegate --> A2A["A2A agent card and task envelope"]
  MCP --> Result["Tool or resource result"]
  A2A --> Artifact["Remote agent artifact"]
  Result --> Policy["Policy and taint checks"]
  Artifact --> Policy
  Policy --> Trace["Trace and audit log"]
  Trace --> State["Session state update"]

