{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.ai/schemas/agent-ontology-artifact-contract/1.0.0",
  "title": "Moonweave Agent Ontology artifact contract",
  "description": "Independent closed contract for editable product/module sources and the generated canonical artifact.",
  "contract_version": "1.0.0",
  "supported_canonical_major": 2,
  "oneOf": [
    { "$ref": "#/$defs/productSource" },
    { "$ref": "#/$defs/moduleSource" },
    { "$ref": "#/$defs/canonicalArtifact" }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "localizedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zh", "en", "ja"],
      "properties": {
        "zh": { "$ref": "#/$defs/nonEmptyString" },
        "en": { "$ref": "#/$defs/nonEmptyString" },
        "ja": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "localizedDraftText": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "zh": { "$ref": "#/$defs/nonEmptyString" },
        "en": { "$ref": "#/$defs/nonEmptyString" },
        "ja": { "$ref": "#/$defs/nonEmptyString" }
      },
      "anyOf": [
        { "required": ["en"] },
        { "required": ["zh"] },
        { "required": ["ja"] }
      ]
    },
    "lifecycleStatus": {
      "enum": ["draft", "review", "accepted", "deprecated"]
    },
    "reviewer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "reviewer_role",
        "reviewer_kind",
        "reviewed_on",
        "decision_note"
      ],
      "properties": {
        "reviewer_id": { "$ref": "#/$defs/identifier" },
        "reviewer_role": {
          "enum": ["architecture", "schema", "ontology", "domain"]
        },
        "reviewer_kind": { "enum": ["human", "automated-agent"] },
        "reviewed_on": { "type": "string", "format": "date" },
        "decision_note": { "$ref": "#/$defs/localizedText" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_status", "reviewers"],
      "properties": {
        "review_status": { "enum": ["draft", "accepted"] },
        "reviewers": {
          "type": "array",
          "items": { "$ref": "#/$defs/reviewer" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "review_status": { "const": "accepted" } },
            "required": ["review_status"]
          },
          "then": {
            "properties": { "reviewers": { "minItems": 1 } }
          }
        }
      ]
    },
    "sourceClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "supports",
        "locator",
        "evidence_kind",
        "confidence",
        "review_status"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/identifier" },
        "supports": { "$ref": "#/$defs/nonEmptyString" },
        "locator": { "$ref": "#/$defs/nonEmptyString" },
        "evidence_kind": {
          "enum": [
            "normative",
            "official",
            "peer-reviewed",
            "vendor",
            "design-inference"
          ]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "review_status": { "enum": ["draft", "accepted"] }
      }
    },
    "sourceClaims": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceClaim" }
    },
    "cardinalityBound": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        }
      }
    },
    "fieldCardinality": { "$ref": "#/$defs/cardinalityBound" },
    "relationCardinality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target"],
      "properties": {
        "source": { "$ref": "#/$defs/cardinalityBound" },
        "target": { "$ref": "#/$defs/cardinalityBound" }
      }
    },
    "controlledValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "value",
        "labels",
        "definitions",
        "status",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "value": {},
        "labels": { "$ref": "#/$defs/localizedText" },
        "definitions": { "$ref": "#/$defs/localizedText" },
        "status": { "const": "accepted" },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "expression_language",
        "expression",
        "explanations",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "severity": { "enum": ["error", "warning", "info"] },
        "expression_language": {
          "enum": ["plain", "json-schema", "shacl", "custom"]
        },
        "expression": { "$ref": "#/$defs/nonEmptyString" },
        "explanations": { "$ref": "#/$defs/localizedText" },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      }
    },
    "requiredRelationConstraint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "direction",
        "predicate",
        "target_concept_id",
        "cardinality",
        "explanations",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "direction": { "enum": ["incoming", "outgoing"] },
        "predicate": { "$ref": "#/$defs/identifier" },
        "target_concept_id": { "$ref": "#/$defs/identifier" },
        "cardinality": { "$ref": "#/$defs/cardinalityBound" },
        "explanations": { "$ref": "#/$defs/localizedText" },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "labels",
        "datatype",
        "required",
        "cardinality",
        "definitions",
        "allowed_values",
        "pattern",
        "example_value",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedText" },
        "datatype": { "$ref": "#/$defs/nonEmptyString" },
        "required": { "type": "boolean" },
        "cardinality": { "$ref": "#/$defs/fieldCardinality" },
        "definitions": { "$ref": "#/$defs/localizedText" },
        "allowed_values": {
          "type": "array",
          "items": { "$ref": "#/$defs/controlledValue" }
        },
        "pattern": {
          "oneOf": [{ "type": "string" }, { "type": "null" }]
        },
        "example_value": {},
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "required": { "const": true } },
            "required": ["required"]
          },
          "then": {
            "properties": {
              "cardinality": {
                "properties": { "min": { "minimum": 1 } }
              }
            }
          },
          "else": {
            "properties": {
              "cardinality": {
                "properties": { "min": { "const": 0 } }
              }
            }
          }
        }
      ]
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "labels",
        "scenario_id",
        "descriptions",
        "field_values",
        "related_node_ids",
        "related_relation_ids",
        "expected_result",
        "why_valid_or_invalid",
        "synthetic",
        "verified_version",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "kind": {
          "enum": [
            "positive",
            "counterexample",
            "boundary",
            "instance",
            "case-fragment"
          ]
        },
        "labels": { "$ref": "#/$defs/localizedText" },
        "scenario_id": {
          "oneOf": [
            { "$ref": "#/$defs/identifier" },
            { "type": "null" }
          ]
        },
        "descriptions": { "$ref": "#/$defs/localizedText" },
        "field_values": {
          "type": "object",
          "additionalProperties": true
        },
        "related_node_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "related_relation_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "expected_result": { "$ref": "#/$defs/localizedText" },
        "why_valid_or_invalid": { "$ref": "#/$defs/localizedText" },
        "synthetic": { "type": "boolean" },
        "verified_version": { "$ref": "#/$defs/nonEmptyString" },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "case-fragment" } },
            "required": ["kind"]
          },
          "then": {
            "properties": {
              "scenario_id": { "$ref": "#/$defs/identifier" }
            }
          }
        }
      ]
    },
    "mappingConformance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "test_id", "method"],
      "properties": {
        "status": {
          "enum": ["contract-tested", "executable-tested", "not-tested"]
        },
        "test_id": { "$ref": "#/$defs/identifier" },
        "method": { "$ref": "#/$defs/localizedText" }
      }
    },
    "externalMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "system",
        "external_identifier",
        "external_version",
        "canonical_target_ids",
        "mapping_kind",
        "scope",
        "direction",
        "loss_notes",
        "conversion_note",
        "conformance",
        "status",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "system": { "$ref": "#/$defs/nonEmptyString" },
        "external_identifier": { "$ref": "#/$defs/nonEmptyString" },
        "external_version": { "$ref": "#/$defs/nonEmptyString" },
        "canonical_target_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "minItems": 1,
          "uniqueItems": true
        },
        "mapping_kind": {
          "enum": ["exact", "broader", "narrower", "related", "lossy", "unsupported"]
        },
        "scope": { "$ref": "#/$defs/localizedText" },
        "direction": {
          "enum": ["import-to-canonical", "export-from-canonical", "bidirectional"]
        },
        "loss_notes": { "$ref": "#/$defs/localizedText" },
        "conversion_note": { "$ref": "#/$defs/localizedText" },
        "conformance": { "$ref": "#/$defs/mappingConformance" },
        "status": { "const": "accepted" },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      }
    },
    "informationBase": {
      "type": "object",
      "properties": {
        "labels": { "$ref": "#/$defs/localizedDraftText" },
        "definitions": { "$ref": "#/$defs/localizedDraftText" },
        "includes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "excludes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      }
    },
    "plane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "labels", "definitions", "status", "review"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedDraftText" },
        "definitions": { "$ref": "#/$defs/localizedDraftText" },
        "purpose": { "$ref": "#/$defs/localizedDraftText" },
        "includes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "excludes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" },
        "status": { "enum": ["draft", "review", "accepted"] },
        "review": { "$ref": "#/$defs/review" },
        "introduced_in": { "$ref": "#/$defs/nonEmptyString" },
        "change_note": { "$ref": "#/$defs/localizedDraftText" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "required": [
              "purpose",
              "includes",
              "excludes",
              "examples",
              "source_claims",
              "introduced_in",
              "change_note"
            ],
            "properties": {
              "labels": { "$ref": "#/$defs/localizedText" },
              "definitions": { "$ref": "#/$defs/localizedText" },
              "purpose": { "$ref": "#/$defs/localizedText" },
              "includes": { "minItems": 1 },
              "excludes": { "minItems": 1 },
              "examples": { "minItems": 1 },
              "source_claims": { "minItems": 1 },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        }
      ]
    },
    "interactionFacet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicable", "not_applicable_reason"],
      "properties": {
        "applicable": { "type": "boolean" },
        "not_applicable_reason": {
          "oneOf": [
            { "$ref": "#/$defs/localizedText" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "applicable": { "const": false } },
            "required": ["applicable"]
          },
          "then": {
            "properties": {
              "not_applicable_reason": { "$ref": "#/$defs/localizedText" }
            }
          },
          "else": {
            "properties": { "not_applicable_reason": { "type": "null" } }
          }
        }
      ]
    },
    "interactionContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicability", "facets", "review"],
      "properties": {
        "applicability": { "enum": ["operational", "descriptive", "mixed"] },
        "facets": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input", "output", "failure", "recovery"],
          "properties": {
            "input": { "$ref": "#/$defs/interactionFacet" },
            "output": { "$ref": "#/$defs/interactionFacet" },
            "failure": { "$ref": "#/$defs/interactionFacet" },
            "recovery": { "$ref": "#/$defs/interactionFacet" }
          }
        },
        "review": { "$ref": "#/$defs/review" }
      }
    },
    "taxonomyContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicability", "not_applicable_reason", "review"],
      "properties": {
        "applicability": { "enum": ["specialization", "flat-root-exception"] },
        "not_applicable_reason": {
          "oneOf": [
            { "$ref": "#/$defs/localizedText" },
            { "type": "null" }
          ]
        },
        "review": { "$ref": "#/$defs/review" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "applicability": { "const": "flat-root-exception" } },
            "required": ["applicability"]
          },
          "then": {
            "properties": {
              "not_applicable_reason": { "$ref": "#/$defs/localizedText" },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          },
          "else": {
            "properties": { "not_applicable_reason": { "type": "null" } }
          }
        }
      ]
    },
    "competencyQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "questions",
        "query",
        "expected_assertion",
        "positive_example_ids",
        "counterexample_ids",
        "source_claims",
        "review"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "questions": { "$ref": "#/$defs/localizedText" },
        "query": { "$ref": "#/$defs/nonEmptyString" },
        "expected_assertion": { "$ref": "#/$defs/nonEmptyString" },
        "positive_example_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "minItems": 1,
          "uniqueItems": true
        },
        "counterexample_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "minItems": 1,
          "uniqueItems": true
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" },
        "review": { "$ref": "#/$defs/review" }
      }
    },
    "module": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "plane_id",
        "labels",
        "definitions",
        "interaction_contract",
        "taxonomy_contract",
        "status",
        "review"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "plane_id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedDraftText" },
        "definitions": { "$ref": "#/$defs/localizedDraftText" },
        "purpose": { "$ref": "#/$defs/localizedDraftText" },
        "includes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "excludes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "interaction_contract": { "$ref": "#/$defs/interactionContract" },
        "taxonomy_contract": { "$ref": "#/$defs/taxonomyContract" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "competency_questions": {
          "type": "array",
          "items": { "$ref": "#/$defs/competencyQuestion" }
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" },
        "status": { "enum": ["draft", "review", "accepted"] },
        "review": { "$ref": "#/$defs/review" },
        "introduced_in": { "$ref": "#/$defs/nonEmptyString" },
        "change_note": { "$ref": "#/$defs/localizedDraftText" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "required": [
              "purpose",
              "includes",
              "excludes",
              "examples",
              "competency_questions",
              "source_claims",
              "introduced_in",
              "change_note"
            ],
            "properties": {
              "labels": { "$ref": "#/$defs/localizedText" },
              "definitions": { "$ref": "#/$defs/localizedText" },
              "purpose": { "$ref": "#/$defs/localizedText" },
              "includes": { "minItems": 1 },
              "excludes": { "minItems": 1 },
              "examples": { "minItems": 1 },
              "competency_questions": { "minItems": 2 },
              "source_claims": { "minItems": 1 },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        }
      ]
    },
    "conceptStructure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_keys",
        "fields",
        "constraints",
        "required_relation_constraints"
      ],
      "properties": {
        "identity_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/field" }
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "required_relation_constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/requiredRelationConstraint" }
        }
      }
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "module_id",
        "labels",
        "definitions",
        "status",
        "review"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "module_id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedDraftText" },
        "short_definitions": { "$ref": "#/$defs/localizedDraftText" },
        "definitions": { "$ref": "#/$defs/localizedDraftText" },
        "why_needed": { "$ref": "#/$defs/localizedDraftText" },
        "includes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "excludes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" }
        },
        "semantic_kind": {
          "oneOf": [
            {
              "enum": [
                "entity",
                "role",
                "capability",
                "information",
                "specification",
                "activity",
                "event",
                "state",
                "quality",
                "collection"
              ]
            },
            { "type": "null" }
          ]
        },
        "primary_parent_relation_id": {
          "oneOf": [
            { "$ref": "#/$defs/identifier" },
            { "type": "null" }
          ]
        },
        "structure": { "$ref": "#/$defs/conceptStructure" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" },
        "external_mappings": {
          "type": "array",
          "items": { "$ref": "#/$defs/externalMapping" }
        },
        "applicability": {
          "type": "array",
          "items": { "enum": ["core", "profile", "adapter"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "status": { "$ref": "#/$defs/lifecycleStatus" },
        "review": { "$ref": "#/$defs/review" },
        "introduced_in": { "$ref": "#/$defs/nonEmptyString" },
        "deprecated_in": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            { "type": "null" }
          ]
        },
        "replaced_by_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "deprecation_reason": {
          "oneOf": [
            { "$ref": "#/$defs/localizedText" },
            { "type": "null" }
          ]
        },
        "change_note": { "$ref": "#/$defs/localizedDraftText" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "required": [
              "short_definitions",
              "why_needed",
              "includes",
              "excludes",
              "semantic_kind",
              "primary_parent_relation_id",
              "structure",
              "examples",
              "source_claims",
              "external_mappings",
              "applicability",
              "introduced_in",
              "deprecated_in",
              "replaced_by_ids",
              "deprecation_reason",
              "change_note"
            ],
            "properties": {
              "labels": { "$ref": "#/$defs/localizedText" },
              "short_definitions": { "$ref": "#/$defs/localizedText" },
              "definitions": { "$ref": "#/$defs/localizedText" },
              "why_needed": { "$ref": "#/$defs/localizedText" },
              "includes": { "minItems": 1 },
              "excludes": { "minItems": 1 },
              "semantic_kind": {
                "enum": [
                  "entity",
                  "role",
                  "capability",
                  "information",
                  "specification",
                  "activity",
                  "event",
                  "state",
                  "quality",
                  "collection"
                ]
              },
              "examples": {
                "minItems": 2,
                "allOf": [
                  { "contains": { "properties": { "kind": { "const": "positive" } } } },
                  {
                    "contains": {
                      "properties": {
                        "kind": { "enum": ["counterexample", "boundary"] }
                      }
                    }
                  }
                ]
              },
              "source_claims": { "minItems": 1 },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "deprecated" } },
            "required": ["status"]
          },
          "then": {
            "required": ["deprecated_in", "replaced_by_ids", "deprecation_reason"],
            "properties": {
              "deprecated_in": { "$ref": "#/$defs/nonEmptyString" },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            },
            "anyOf": [
              { "properties": { "replaced_by_ids": { "minItems": 1 } } },
              { "properties": { "deprecation_reason": { "$ref": "#/$defs/localizedText" } } }
            ]
          }
        }
      ]
    },
    "inverseReading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["predicate", "labels"],
      "properties": {
        "predicate": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedText" }
      }
    },
    "boundaryContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trust_boundary_concept_id",
        "authority_basis",
        "protocol_or_resource_context"
      ],
      "properties": {
        "trust_boundary_concept_id": { "$ref": "#/$defs/identifier" },
        "authority_basis": { "$ref": "#/$defs/localizedText" },
        "protocol_or_resource_context": { "$ref": "#/$defs/localizedText" }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "predicate",
        "source_id",
        "target_id",
        "direction",
        "relation_kind",
        "status",
        "review"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "predicate": { "$ref": "#/$defs/identifier" },
        "source_id": { "$ref": "#/$defs/identifier" },
        "target_id": { "$ref": "#/$defs/identifier" },
        "direction": { "const": "source-to-target" },
        "relation_kind": {
          "enum": [
            "hierarchy",
            "composition",
            "causal",
            "temporal",
            "information",
            "governance",
            "mapping"
          ]
        },
        "labels": { "$ref": "#/$defs/localizedDraftText" },
        "definitions": { "$ref": "#/$defs/localizedDraftText" },
        "cardinality": {
          "oneOf": [
            { "$ref": "#/$defs/relationCardinality" },
            { "type": "null" }
          ]
        },
        "cardinality_not_applicable_reason": {
          "oneOf": [
            { "$ref": "#/$defs/localizedText" },
            { "type": "null" }
          ]
        },
        "inverse_reading": { "$ref": "#/$defs/inverseReading" },
        "conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "temporal_scope": {
          "enum": ["timeless", "valid-time", "transaction-time"]
        },
        "boundary_context": {
          "oneOf": [
            { "$ref": "#/$defs/boundaryContext" },
            { "type": "null" }
          ]
        },
        "constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" }
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" },
        "distinct_fact_rationale": {
          "oneOf": [
            { "$ref": "#/$defs/localizedText" },
            { "type": "null" }
          ]
        },
        "status": { "$ref": "#/$defs/lifecycleStatus" },
        "review": { "$ref": "#/$defs/review" },
        "introduced_in": { "$ref": "#/$defs/nonEmptyString" },
        "deprecated_in": {
          "oneOf": [
            { "$ref": "#/$defs/nonEmptyString" },
            { "type": "null" }
          ]
        },
        "replaced_by_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "deprecation_reason": {
          "oneOf": [
            { "$ref": "#/$defs/localizedText" },
            { "type": "null" }
          ]
        },
        "change_note": { "$ref": "#/$defs/localizedDraftText" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "predicate": { "const": "is_a" } },
            "required": ["predicate"]
          },
          "then": {
            "properties": {
              "relation_kind": { "const": "hierarchy" },
              "cardinality": { "type": "null" },
              "cardinality_not_applicable_reason": { "$ref": "#/$defs/localizedText" },
              "temporal_scope": { "const": "timeless" },
              "boundary_context": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "predicate": { "pattern": "(?:^|_)crosses_trust_boundary$" }
            },
            "required": ["predicate"]
          },
          "then": {
            "required": ["boundary_context"],
            "properties": {
              "boundary_context": { "$ref": "#/$defs/boundaryContext" }
            }
          }
        },
        {
          "if": {
            "properties": { "cardinality": { "type": "null" } },
            "required": ["cardinality"]
          },
          "then": {
            "properties": {
              "cardinality_not_applicable_reason": { "$ref": "#/$defs/localizedText" }
            }
          },
          "else": {
            "properties": {
              "cardinality_not_applicable_reason": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "required": [
              "labels",
              "definitions",
              "cardinality",
              "cardinality_not_applicable_reason",
              "inverse_reading",
              "conditions",
              "temporal_scope",
              "boundary_context",
              "constraints",
              "examples",
              "source_claims",
              "distinct_fact_rationale",
              "introduced_in",
              "deprecated_in",
              "replaced_by_ids",
              "deprecation_reason",
              "change_note"
            ],
            "properties": {
              "labels": { "$ref": "#/$defs/localizedText" },
              "definitions": { "$ref": "#/$defs/localizedText" },
              "examples": {
                "minItems": 2,
                "allOf": [
                  { "contains": { "properties": { "kind": { "const": "positive" } } } },
                  {
                    "contains": {
                      "properties": {
                        "kind": { "enum": ["counterexample", "boundary"] }
                      }
                    }
                  }
                ]
              },
              "source_claims": { "minItems": 1 },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "status": { "const": "deprecated" } },
            "required": ["status"]
          },
          "then": {
            "required": ["deprecated_in", "replaced_by_ids", "deprecation_reason"],
            "properties": {
              "deprecated_in": { "$ref": "#/$defs/nonEmptyString" },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            },
            "anyOf": [
              { "properties": { "replaced_by_ids": { "minItems": 1 } } },
              { "properties": { "deprecation_reason": { "$ref": "#/$defs/localizedText" } } }
            ]
          }
        }
      ]
    },
    "casePathStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order", "case_fragment_example_id", "traversal_relation_id"],
      "properties": {
        "order": { "type": "integer", "minimum": 1 },
        "case_fragment_example_id": { "$ref": "#/$defs/identifier" },
        "traversal_relation_id": {
          "oneOf": [
            { "$ref": "#/$defs/identifier" },
            { "type": "null" }
          ]
        }
      }
    },
    "casePath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "labels",
        "descriptions",
        "steps",
        "source_claims",
        "status",
        "review"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedText" },
        "descriptions": { "$ref": "#/$defs/localizedText" },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/casePathStep" },
          "minItems": 1
        },
        "source_claims": { "$ref": "#/$defs/sourceClaims" },
        "status": { "enum": ["draft", "review", "accepted"] },
        "review": { "$ref": "#/$defs/review" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        }
      ]
    },
    "hygieneGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "labels",
        "descriptions",
        "severity",
        "check_kind",
        "expression",
        "status",
        "source_claims"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedText" },
        "descriptions": { "$ref": "#/$defs/localizedText" },
        "severity": { "enum": ["error", "warning", "info"] },
        "check_kind": {
          "enum": ["schema", "taxonomy", "reference", "information", "generation", "ui"]
        },
        "expression": { "$ref": "#/$defs/nonEmptyString" },
        "status": { "const": "accepted" },
        "source_claims": { "$ref": "#/$defs/sourceClaims" }
      }
    },
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "labels",
        "short_definitions",
        "definitions",
        "why_needed",
        "includes",
        "excludes",
        "examples",
        "source_claims",
        "status",
        "review",
        "date",
        "canonical_version"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedText" },
        "short_definitions": { "$ref": "#/$defs/localizedText" },
        "definitions": { "$ref": "#/$defs/localizedText" },
        "why_needed": { "$ref": "#/$defs/localizedText" },
        "includes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" },
          "minItems": 1
        },
        "excludes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" },
          "minItems": 1
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" },
          "minItems": 1
        },
        "source_claims": {
          "allOf": [
            { "$ref": "#/$defs/sourceClaims" },
            { "minItems": 1 }
          ]
        },
        "status": {
          "enum": ["draft-hierarchy-upgrade", "review", "accepted"]
        },
        "review": { "$ref": "#/$defs/review" },
        "date": { "type": "string", "format": "date" },
        "canonical_version": { "$ref": "#/$defs/nonEmptyString" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        }
      ]
    },
    "artifactMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_kind",
        "contract_version",
        "canonical_version",
        "release_channel",
        "releasable",
        "generated",
        "do_not_edit",
        "generated_from",
        "generator_version",
        "generated_at",
        "source_tree_sha256"
      ],
      "properties": {
        "artifact_kind": { "const": "canonical-agent-ontology" },
        "contract_version": { "const": "1.0.0" },
        "canonical_version": { "$ref": "#/$defs/nonEmptyString" },
        "release_channel": { "enum": ["candidate", "release"] },
        "releasable": { "type": "boolean" },
        "generated": { "const": true },
        "do_not_edit": { "const": true },
        "generated_from": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" },
          "minItems": 1,
          "uniqueItems": true
        },
        "generator_version": { "$ref": "#/$defs/nonEmptyString" },
        "generated_at": { "type": "string", "format": "date-time" },
        "source_tree_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "release_channel": { "const": "release" } },
            "required": ["release_channel"]
          },
          "then": {
            "properties": { "releasable": { "const": true } }
          },
          "else": {
            "properties": { "releasable": { "const": false } }
          }
        }
      ]
    },
    "ontologyMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domains",
        "modules",
        "concepts",
        "taxonomy_roots",
        "is_a_relations",
        "semantic_relations",
        "instance_examples",
        "controlled_values",
        "structure_fields",
        "constraints",
        "source_claims",
        "case_paths",
        "legacy_individuals_remaining",
        "legacy_data_properties_remaining",
        "legacy_axioms_remaining"
      ],
      "properties": {
        "domains": { "type": "integer", "minimum": 0 },
        "modules": { "type": "integer", "minimum": 0 },
        "concepts": { "type": "integer", "minimum": 0 },
        "taxonomy_roots": { "type": "integer", "minimum": 0 },
        "is_a_relations": { "type": "integer", "minimum": 0 },
        "semantic_relations": { "type": "integer", "minimum": 0 },
        "instance_examples": { "type": "integer", "minimum": 0 },
        "controlled_values": { "type": "integer", "minimum": 0 },
        "structure_fields": { "type": "integer", "minimum": 0 },
        "constraints": { "type": "integer", "minimum": 0 },
        "source_claims": { "type": "integer", "minimum": 0 },
        "case_paths": { "type": "integer", "minimum": 0 },
        "legacy_individuals_remaining": { "type": "integer", "minimum": 0 },
        "legacy_data_properties_remaining": { "type": "integer", "minimum": 0 },
        "legacy_axioms_remaining": { "type": "integer", "minimum": 0 }
      }
    },
    "productSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "contract_version",
        "product",
        "planes",
        "global_constraints",
        "case_paths",
        "hygiene_gates"
      ],
      "properties": {
        "source_kind": { "const": "agent-ontology-product" },
        "contract_version": { "const": "1.0.0" },
        "product": { "$ref": "#/$defs/product" },
        "planes": {
          "type": "array",
          "items": { "$ref": "#/$defs/plane" },
          "minItems": 1
        },
        "global_constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "case_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/casePath" }
        },
        "hygiene_gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/hygieneGate" }
        }
      }
    },
    "moduleSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_kind", "contract_version", "module", "classes", "relations"],
      "properties": {
        "source_kind": { "const": "agent-ontology-module" },
        "contract_version": { "const": "1.0.0" },
        "module": { "$ref": "#/$defs/module" },
        "classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/concept" }
        },
        "relations": {
          "type": "array",
          "items": { "$ref": "#/$defs/relation" }
        }
      }
    },
    "canonicalArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "labels",
        "short_definitions",
        "definitions",
        "why_needed",
        "includes",
        "excludes",
        "examples",
        "source_claims",
        "status",
        "review",
        "date",
        "artifact_metadata",
        "planes",
        "modules",
        "classes",
        "relations",
        "global_constraints",
        "case_paths",
        "hygiene_gates",
        "ontology_metrics"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "labels": { "$ref": "#/$defs/localizedText" },
        "short_definitions": { "$ref": "#/$defs/localizedText" },
        "definitions": { "$ref": "#/$defs/localizedText" },
        "why_needed": { "$ref": "#/$defs/localizedText" },
        "includes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" },
          "minItems": 1
        },
        "excludes": {
          "type": "array",
          "items": { "$ref": "#/$defs/localizedText" },
          "minItems": 1
        },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" },
          "minItems": 1
        },
        "source_claims": {
          "allOf": [
            { "$ref": "#/$defs/sourceClaims" },
            { "minItems": 1 }
          ]
        },
        "status": {
          "enum": ["draft-hierarchy-upgrade", "review", "accepted"]
        },
        "review": { "$ref": "#/$defs/review" },
        "date": { "type": "string", "format": "date" },
        "artifact_metadata": { "$ref": "#/$defs/artifactMetadata" },
        "planes": {
          "type": "array",
          "items": { "$ref": "#/$defs/plane" },
          "minItems": 1
        },
        "modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/module" },
          "minItems": 1
        },
        "classes": {
          "type": "array",
          "items": { "$ref": "#/$defs/concept" },
          "minItems": 1
        },
        "relations": {
          "type": "array",
          "items": { "$ref": "#/$defs/relation" }
        },
        "global_constraints": {
          "type": "array",
          "items": { "$ref": "#/$defs/constraint" }
        },
        "case_paths": {
          "type": "array",
          "items": { "$ref": "#/$defs/casePath" }
        },
        "hygiene_gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/hygieneGate" }
        },
        "ontology_metrics": { "$ref": "#/$defs/ontologyMetrics" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "accepted" } },
            "required": ["status"]
          },
          "then": {
            "properties": {
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "artifact_metadata": {
                "properties": { "release_channel": { "const": "release" } },
                "required": ["release_channel"]
              }
            },
            "required": ["artifact_metadata"]
          },
          "then": {
            "properties": {
              "status": { "const": "accepted" },
              "review": {
                "properties": { "review_status": { "const": "accepted" } }
              }
            }
          }
        }
      ]
    }
  }
}
