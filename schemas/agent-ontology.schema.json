{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://moonweave.ai/schemas/agent-ontology.schema.json",
  "title": "Moonweave Agent Ontology Dataset",
  "type": "object",
  "required": ["id", "artifact_type", "version", "title", "review_status", "generated_from", "artifacts", "relations"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "artifact_type": { "const": "GraphView" },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "review_status": { "$ref": "#/$defs/reviewStatus" },
    "generated_from": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" },
      "minItems": 1
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation" },
      "minItems": 1
    }
  },
  "$defs": {
    "reviewStatus": {
      "enum": ["accepted", "draft", "needs-review"]
    },
    "disposition": {
      "enum": ["core", "core+profile", "profile", "adapter"]
    },
    "layer": {
      "enum": [
        "evidence",
        "actor-boundary",
        "runtime-trace",
        "task-action-observation",
        "security-policy",
        "validation",
        "capability-resource",
        "memory-context",
        "orchestration",
        "statechart",
        "evaluation"
      ]
    },
    "provenance": {
      "type": "object",
      "required": ["source_ids", "constraint_ids", "proposal_ids", "derivation_note", "review_status"],
      "additionalProperties": false,
      "properties": {
        "source_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(eng|lit)-" },
          "minItems": 1,
          "uniqueItems": true
        },
        "constraint_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^SC-" },
          "minItems": 1,
          "uniqueItems": true
        },
        "proposal_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(PL|PR)-" },
          "minItems": 1,
          "uniqueItems": true
        },
        "derivation_note": { "type": "string", "minLength": 1 },
        "review_status": { "$ref": "#/$defs/reviewStatus" }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["id", "artifact_type", "label", "layer", "disposition", "description", "provenance"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "artifact_type": {
          "enum": ["OntologyArtifact", "TrustBoundary", "SchemaArtifact", "GraphView", "ConversionWarning"]
        },
        "label": { "type": "string", "minLength": 1 },
        "layer": { "$ref": "#/$defs/layer" },
        "disposition": { "$ref": "#/$defs/disposition" },
        "description": { "type": "string", "minLength": 1 },
        "provenance": { "$ref": "#/$defs/provenance" }
      }
    },
    "relation": {
      "type": "object",
      "required": [
        "id",
        "artifact_type",
        "label",
        "layer",
        "disposition",
        "description",
        "provenance",
        "relation_kind",
        "source_artifact_id",
        "target_artifact_id",
        "direction"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "artifact_type": { "const": "RelationArtifact" },
        "label": { "type": "string", "minLength": 1 },
        "layer": { "$ref": "#/$defs/layer" },
        "disposition": { "$ref": "#/$defs/disposition" },
        "description": { "type": "string", "minLength": 1 },
        "provenance": { "$ref": "#/$defs/provenance" },
        "relation_kind": {
          "enum": [
            "derives_claim_from_source",
            "crosses_trust_boundary",
            "records_observable_trace_event",
            "plans_task_for_goal",
            "observes_execution_result",
            "exposes_capability_surface",
            "delegates_to_remote_agent",
            "transitions_state_on_event",
            "evaluates_run_on_benchmark"
          ]
        },
        "source_artifact_id": { "type": "string", "minLength": 1 },
        "target_artifact_id": { "type": "string", "minLength": 1 },
        "trust_boundary_id": { "type": "string", "minLength": 1 },
        "direction": { "enum": ["source-to-target", "bidirectional"] }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "relation_kind": { "const": "crosses_trust_boundary" }
            },
            "required": ["relation_kind"]
          },
          "then": {
            "properties": {
              "trust_boundary_id": { "type": "string", "minLength": 1 }
            },
            "required": ["trust_boundary_id"]
          }
        },
        {
          "if": {
            "properties": {
              "relation_kind": { "const": "delegates_to_remote_agent" }
            },
            "required": ["relation_kind"]
          },
          "then": {
            "properties": {
              "trust_boundary_id": { "type": "string", "minLength": 1 }
            },
            "required": ["trust_boundary_id"]
          }
        }
      ]
    }
  }
}
