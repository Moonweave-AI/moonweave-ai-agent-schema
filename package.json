{
  "name": "agent-schema",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Agent ontology engineering framework with canonical schema, graph IR, and Moonweave explorer",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && npm run site:manifest && npm run site:verify",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "npm run typecheck",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude tests/ontology-community-network-performance.test.ts",
    "e2e": "playwright test",
    "dependency:policy": "node scripts/verify-dependency-policy.mjs",
    "dependency:audit": "node scripts/audit-npm-dependencies.mjs",
    "dependency:python": "python scripts/verify-python-dependency-policy.py",
    "dependency:security": "npm run dependency:policy && npm run dependency:audit && npm run dependency:python",
    "ontology:expand": "node scripts/expand-agent-ontology.mjs",
    "ontology:migrate": "node scripts/verify-legacy-ontology-migration-audit.mjs",
    "ontology:migrate:check": "node scripts/verify-legacy-ontology-migration-audit.mjs",
    "ontology:legacy:audit": "node scripts/verify-legacy-ontology-migration-audit.mjs",
    "ontology:legacy:replay": "node scripts/apply-reviewed-ontology-migration.mjs --legacy-replay",
    "ontology:build": "node scripts/build-agent-ontology.mjs",
    "ontology:release": "node scripts/release-agent-ontology.mjs",
    "ontology:check": "node scripts/release-agent-ontology.mjs --check",
    "ontology:check-generated": "npm run ontology:check",
    "ontology:validate": "vitest run --exclude tests/ontology-community-network-performance.test.ts && vitest run tests/ontology-community-network-performance.test.ts --maxWorkers=1 --no-file-parallelism",
    "ontology:client:validate": "vitest run tests/ontology-client-loading.test.ts",
    "ontology:shared-prefix": "vitest run tests/ontology-shared-prefix-audit.test.ts",
    "ontology:security": "node scripts/verify-ontology-security.mjs",
    "ontology:check-links": "node scripts/check-source-links.mjs --referenced-only --allow-inconclusive",
    "ontology:visual:update": "node scripts/capture-ontology-visual-baseline.mjs",
    "ontology:communities:generate": "python scripts/generate-ontology-community-graph.py",
    "ontology:communities:check": "node scripts/verify-ontology-community-graph.mjs",
    "ontology:communities:test": "python -m unittest discover -s tests/python -p \"test_*.py\" -v",
    "ontology:communities:verify": "npm run ontology:communities:test && npm run ontology:communities:generate && npm run ontology:communities:check && git diff --exit-code -- src/generated/ontology-community-graph.json",
    "site:manifest": "node scripts/write-site-build-manifest.mjs",
    "site:verify": "node scripts/verify-site-artifact.mjs",
    "site:verify-deployment": "node scripts/verify-deployment.mjs",
    "ontology:preflight": "npm run dependency:security && npm run ontology:security && npm run ontology:check-links",
    "ontology:verify": "npm run ontology:communities:verify && npm run ontology:validate && npm run ontology:client:validate && npm run ontology:shared-prefix && npm run ontology:preflight && npm run ontology:check",
    "worktree:check-clean": "node scripts/check-clean-worktree.mjs",
    "test:ontology-ui": "playwright test e2e/ontology-explorer.spec.ts e2e/ontology-explorer-core.spec.ts e2e/ontology-explorer-dense-performance.spec.ts",
    "verify": "npm run ontology:verify && npm run test:coverage && npm run typecheck && npm run build && npm run e2e",
    "ecc:install": "npm run ecc:install:cursor && npm run ecc:install:codex",
    "ecc:install:cursor": "node node_modules/ecc-universal/scripts/install-apply.js --target cursor --profile core && node scripts/patch-cursor-adapter.js",
    "ecc:install:codex:project": "node scripts/sync-codex-project.js",
    "ecc:install:codex:home": "node node_modules/ecc-universal/scripts/install-apply.js --target codex --profile core",
    "ecc:install:codex": "npm run ecc:install:codex:project && npm run ecc:install:codex:home",
    "ecc:doctor": "node node_modules/ecc-universal/scripts/ecc.js doctor --target cursor"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vis-data": "^7.1.10",
    "vis-network": "^9.1.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "ecc-universal": "^2.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19"
  }
}
