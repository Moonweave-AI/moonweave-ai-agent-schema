{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://moonweave.ai/agent-ontology/graph.schema.json",
  "title": "Agent Ontology Graph Schema",
  "description": "JSON Schema for all ontology YAML artifacts: NodeClass, EdgeClass, InterfaceContract, StateMachine, GraphConstraint, GraphView, EvidenceRef, SourceClaim, BenchmarkRef",
  "oneOf": [
    { "$ref": "#/definitions/NodeClass" },
    { "$ref": "#/definitions/EdgeClass" },
    { "$ref": "#/definitions/InterfaceContract" },
    { "$ref": "#/definitions/StateMachine" },
    { "$ref": "#/definitions/GraphConstraint" },
    { "$ref": "#/definitions/GraphView" },
    { "$ref": "#/definitions/EvidenceRef" },
    { "$ref": "#/definitions/SourceClaim" },
    { "$ref": "#/definitions/BenchmarkRef" }
  ],
  "definitions": {
    "NodeClass": {
      "type": "object",
      "required": [
        "id",
        "artifact",
        "label",
        "description",
        "description_zh",
        "intra_level",
        "intra_axis",
        "intra_axis_zh",
        "intra_group",
        "intra_group_zh",
        "intra_role"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^node\\." },
        "artifact": { "const": "NodeClass" },
        "label": { "type": "string" },
        "label_zh": { "type": "string" },
        "intra_level": {
          "type": "integer",
          "minimum": 0,
          "description": "Depth of the node inside its owning subgraph. Level 0 is the subgraph anchor; higher levels are increasingly specialized structures, mechanisms, artifacts, or signals."
        },
        "intra_axis": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Stable semantic direction or swimlane inside a subgraph level. Axis is coarser than intra_group and separates parallel concern directions such as identity, cognition, intent, execution, governance, retrieval, or validation."
        },
        "intra_axis_zh": {
          "type": "string",
          "description": "Chinese display label for the semantic axis or swimlane."
        },
        "intra_group": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Stable semantic group slug used to cluster peer nodes inside the same subgraph."
        },
        "intra_group_zh": {
          "type": "string",
          "description": "Chinese display label for the semantic group."
        },
        "intra_role": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "Role of the node inside its local subgraph hierarchy: anchor, boundary, process, policy, artifact, signal, adapter, validator, and similar ontology roles."
        },
        "parent_node": {
          "type": "string",
          "pattern": "^node\\.",
          "description": "Optional parent NodeClass id inside the same subgraph. Required by validation for non-root intra-subgraph nodes."
        },
        "layer": { "type": "string" },
        "plane": { "type": "string" },
        "description": { "type": "string" },
        "description_zh": { "type": "string" },
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "values": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" }
            }
          }
        },
        "interfaces": {
          "type": "array",
          "items": { "type": "object", "properties": { "ref": { "type": "string" } } }
        },
        "state_machine": {
          "type": "object",
          "properties": { "ref": { "type": "string" } }
        },
        "required_edges": {
          "type": "object",
          "properties": {
            "outgoing": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "predicate": { "type": "string" },
                  "target": { "type": "string" },
                  "target_any_of": { "type": "array", "items": { "type": "string" } }
                }
              }
            },
            "incoming": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "predicate": { "type": "string" },
                  "source": { "type": "string" },
                  "source_any_of": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "object", "properties": { "ref": { "type": "string" } } }
        },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "EdgeClass": {
      "type": "object",
      "required": ["id", "artifact", "predicate", "source_domain", "target_range", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^edge\\." },
        "artifact": { "const": "EdgeClass" },
        "predicate": { "type": "string" },
        "source_domain": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "target_range": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ]
        },
        "cardinality": { "type": "string", "enum": ["1:1", "1:N", "N:1", "N:M"] },
        "description": { "type": "string" },
        "attributes": { "type": "object" },
        "policy": { "type": "object", "properties": { "ref": { "type": "string" } } },
        "evidence": {
          "type": "array",
          "items": { "type": "object", "properties": { "ref": { "type": "string" } } }
        },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "InterfaceContract": {
      "type": "object",
      "required": ["id", "artifact", "label", "description", "operations"],
      "properties": {
        "id": { "type": "string", "pattern": "^contract\\." },
        "artifact": { "const": "InterfaceContract" },
        "label": { "type": "string" },
        "label_zh": { "type": "string" },
        "description": { "type": "string" },
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "input": { "type": "object" },
              "output": { "type": "object" },
              "errors": { "type": "array", "items": { "type": "string" } },
              "description": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "StateMachine": {
      "type": "object",
      "required": ["id", "artifact", "label", "states", "transitions"],
      "properties": {
        "id": { "type": "string", "pattern": "^state\\." },
        "artifact": { "const": "StateMachine" },
        "label": { "type": "string" },
        "label_zh": { "type": "string" },
        "description": { "type": "string" },
        "states": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "terminal": { "type": "boolean" },
              "initial": { "type": "boolean" },
              "description": { "type": "string" }
            }
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "trigger"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "trigger": { "type": "string" },
              "guard": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "GraphConstraint": {
      "type": "object",
      "required": ["id", "artifact", "label", "rule"],
      "properties": {
        "id": { "type": "string", "pattern": "^constraint\\." },
        "artifact": { "const": "GraphConstraint" },
        "label": { "type": "string" },
        "label_zh": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "rule": { "type": "string" },
        "applies_to": {
          "type": "object",
          "properties": {
            "nodes": { "type": "array", "items": { "type": "string" } },
            "edges": { "type": "array", "items": { "type": "string" } }
          }
        },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "GraphView": {
      "type": "object",
      "required": ["id", "artifact", "label", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^view\\." },
        "artifact": { "const": "GraphView" },
        "label": { "type": "string" },
        "label_zh": { "type": "string" },
        "description": { "type": "string" },
        "root_nodes": { "type": "array", "items": { "type": "string" } },
        "included_subgraphs": { "type": "array", "items": { "type": "string" } },
        "edge_filter": { "type": "array", "items": { "type": "string" } },
        "layout": { "type": "string", "enum": ["force", "hierarchical", "radial", "layered"] },
        "audience": { "type": "array", "items": { "type": "string" } },
        "view_type": {
          "type": "string",
          "enum": ["ontology", "evidence_matrix", "protocol_flow", "runtime_trace", "safety_surface", "evaluation_coverage", "architecture"]
        },
        "diagram_notation": {
          "type": "array",
          "items": { "type": "string", "enum": ["d3", "mermaid", "dot", "c4", "bpmn", "svg", "png"] }
        },
        "layout_engine": { "type": "string" },
        "source_filters": { "type": "array", "items": { "type": "string" } },
        "export_targets": { "type": "array", "items": { "type": "string" } },
        "acceptance_queries": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "EvidenceRef": {
      "type": "object",
      "required": ["id", "artifact", "source_type", "description"],
      "properties": {
        "id": { "type": "string", "pattern": "^evidence\\." },
        "artifact": { "const": "EvidenceRef" },
        "source_type": { "type": "string", "enum": ["diagram", "paper", "protocol_spec", "framework_doc", "sdk_doc", "blog", "standard", "benchmark", "dataset"] },
        "source_name": { "type": "string" },
        "location": { "type": "string" },
        "authority_tier": { "type": "string", "enum": ["A", "B", "C"] },
        "venue": { "type": "string" },
        "year": { "type": "integer" },
        "url": { "type": "string" },
        "doi": { "type": "string" },
        "arxiv": { "type": "string" },
        "official_repo": { "type": "string" },
        "last_verified": { "type": "string" },
        "claim_scope": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "deprecated", "removed"], "default": "active" }
      }
    },
    "SourceClaim": {
      "type": "object",
      "required": ["id", "artifact", "source_id", "claim", "ontology_impact"],
      "properties": {
        "id": { "type": "string", "pattern": "^claim\\." },
        "artifact": { "const": "SourceClaim" },
        "source_id": { "type": "string", "pattern": "^source\\." },
        "claim": { "type": "string" },
        "ontology_impact": { "type": "string" },
        "themes": { "type": "array", "items": { "type": "string" } },
        "supports_nodes": { "type": "array", "items": { "type": "string", "pattern": "^node\\." } },
        "supports_edges": { "type": "array", "items": { "type": "string", "pattern": "^edge\\." } },
        "supports_constraints": { "type": "array", "items": { "type": "string", "pattern": "^constraint\\." } },
        "supports_views": { "type": "array", "items": { "type": "string", "pattern": "^view\\." } },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "status": { "type": "string", "enum": ["normative", "exemplar", "candidate", "deprecated"], "default": "candidate" }
      }
    },
    "BenchmarkRef": {
      "type": "object",
      "required": ["id", "artifact", "source_id", "task_domain", "metrics"],
      "properties": {
        "id": { "type": "string", "pattern": "^benchmark\\." },
        "artifact": { "const": "BenchmarkRef" },
        "source_id": { "type": "string", "pattern": "^source\\." },
        "task_domain": { "type": "string" },
        "environment": { "type": "string" },
        "metrics": { "type": "array", "items": { "type": "string" } },
        "supported_capabilities": { "type": "array", "items": { "type": "string" } },
        "known_limitations": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["active", "candidate", "deprecated"], "default": "candidate" }
      }
    }
  }
}
